{
  "name": "osm-traffic-sign-tools-monorepo",
  "private": true,
  "scripts": {
    "bleach": "turbo run bleach && rm -rf node_modules",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "format": "oxfmt --config ./oxfmt.config.mjs --write .",
    "format:check": "oxfmt --config ./oxfmt.config.mjs --check .",
    "lint": "turbo run lint",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "release": "bun run release-cli.ts",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "updatePackages:major": "pnpm dlx taze -r major --includeLocked --write --maturity-period 5 && pnpm install",
    "updatePackages:minor": "pnpm dlx taze -r minor --includeLocked --write --maturity-period 5 && pnpm install"
  },
  "devDependencies": {
    "@clack/prompts": "^0.8.2",
    "@colors/colors": "^1.6.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "oxc-plugin-react-compiler": "^0.2.0",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "postcss": "^8.5.6",
    "svgo": "^4.0.0",
    "turbo": "^2.7.1",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22.21.1"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
