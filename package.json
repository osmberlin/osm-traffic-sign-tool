{
  "name": "osm-traffic-sign-tools-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bleach": "bun run --filter '*' bleach && rm -rf node_modules",
    "build": "bun run build:packages && bun run --cwd apps/traffic-sign-tool build",
    "build:packages": "bun run --cwd packages/traffic-sign-converter build && bun run --cwd packages/internal_taginfo build && bun run --cwd packages/internal_svgs build && bun run --cwd packages/internal_wiki build",
    "check": "bun run format && bun run --filter '*' check",
    "check:clean-build": "bun run ./script-check-clean-build.ts",
    "dev": "bun run --parallel --filter '*' dev",
    "format": "oxfmt --config ./oxfmt.config.mjs --write .",
    "format:check": "oxfmt --config ./oxfmt.config.mjs --check .",
    "format:files": "oxfmt --config ./oxfmt.config.mjs --write",
    "lint": "bun run --filter '*' lint",
    "prepare": "husky",
    "release": "bun run release-cli.ts",
    "test": "bun run --filter '*' test",
    "test:watch": "bun run --parallel --filter '*' test:watch",
    "updatePackages:major": "bunx taze -r major --includeLocked --write --maturity-period 5 && bun install",
    "updatePackages:minor": "bunx taze -r minor --includeLocked --write --maturity-period 5 && bun install"
  },
  "devDependencies": {
    "@clack/prompts": "^0.8.2",
    "@colors/colors": "^1.6.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "oxc-plugin-react-compiler": "^0.2.0",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "postcss": "^8.5.6",
    "svgo": "^4.0.0",
    "vitest": "^4.0.16"
  },
  "nano-staged": {
    "*": "bun run format:files --"
  },
  "engines": {
    "node": ">=22.21.1"
  },
  "packageManager": "bun@1.3.13"
}
