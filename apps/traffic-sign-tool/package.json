{
  "name": "osm-traffic-sign-tool",
  "version": "2.1.9",
  "private": true,
  "description": "Get OpenStreetMap tagging recommendations based on traffic sign combinations.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "bleach": "rm -rf node_modules && rm -rf .next/",
    "build": "bun run build:paraglide && bun run build:vite",
    "build:gh-pages": "bun run build && cp dist/index.html dist/404.html",
    "build:paraglide": "paraglide-js compile --project ./project.inlang --outdir ./paraglide --strategy localStorage baseLocale",
    "build:vite": "vite build",
    "check": "bun run type-check && bun run format && bun run lint",
    "dev": "vite",
    "format": "oxfmt --config ../../oxfmt.config.mjs --write .",
    "format:check": "oxfmt --config ../../oxfmt.config.mjs --check .",
    "lint": "oxlint -c ../../oxlint.config.mjs .",
    "preview": "vite preview",
    "start": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch --passWithNoTests",
    "type-check": "tsc --skipLibCheck --noEmit",
    "updatePackages:major": "bunx taze major --includeLocked --write --maturity-period 5 --exclude eslint && bun run updatePackages:minor && bun install",
    "updatePackages:minor": "bunx taze minor --includeLocked --write --maturity-period 5"
  },
  "dependencies": {
    "@fontsource-variable/fira-code": "^5.2.7",
    "@fontsource/fira-sans": "^5.2.7",
    "@fontsource/fira-sans-condensed": "^5.2.7",
    "@fontsource/noto-serif": "^5.2.9",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@inlang/paraglide-js": "^2.18.1",
    "@inlang/paraglide-js-react": "^1.0.2",
    "@internal/taginfo": "workspace:*",
    "@internal/wiki": "workspace:*",
    "@osm-traffic-signs/converter": "workspace:*",
    "@tanstack/react-router": "^1.139.3",
    "@tanstack/router-devtools": "^1.139.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "micromark": "^4.0.2",
    "micromark-extension-gfm": "^3.0.0",
    "opening_hours": "^3.12.0",
    "react": "^19.0.3",
    "react-dom": "^19.0.3",
    "sharp": "^0.34.5",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@inlang/plugin-m-function-matcher": "^2.2.6",
    "@inlang/plugin-message-format": "^4.4.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/router-plugin": "^1.139.3",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.0.16"
  }
}
