{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "noErrorTruncation": true, // https://stackoverflow.com/a/53131824
    "baseUrl": ".",
    "paths": {
      "@app/*": ["./*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "**/*.test.ts"
  ],
  "exclude": ["node_modules", "app/_components/catalyst/_unused/**"]
}
