{
  "name": "@internal/svgs",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bleach": "rm -rf .turbo && rm -rf node_modules",
    "build": "pnpm run build:clean && pnpm run build:ts && pnpm run build:copy-svgs",
    "build:clean": "rimraf dist",
    "build:copy-svgs": "copyfiles --flat './src/data/svgs/*' './dist/data/svgs'",
    "build:ts": "tsc",
    "check": "pnpm run type-check && pnpm run format && pnpm run lint",
    "dev": "tsc --watch",
    "format": "oxfmt --config ../../oxfmt.config.mjs --write .",
    "format:check": "oxfmt --config ../../oxfmt.config.mjs --check .",
    "lint": "oxlint -c ../../oxlint.config.mjs .",
    "preinstall": "npx only-allow pnpm",
    "test": "echo No tests configured",
    "test:watch": "echo No tests configured",
    "type-check": "tsc --skipLibCheck --noEmit",
    "updateSvgs:clean": "rimraf ./src/data-svgs",
    "updateSvgs:download:full": "DOWNLOAD_MODE=full bun ./src/downloadAndOptimizeSvgs.ts",
    "updateSvgs:download:incremental": "DOWNLOAD_MODE=incremental bun ./src/downloadAndOptimizeSvgs.ts",
    "updateSvgs:force-refresh": "npm run updateSvgs:clean && npm run updateSvgs:download:full && npm run updateSvgs:format",
    "updateSvgs:format": "oxfmt --config ../../oxfmt.config.mjs --write ./src/data-svgs",
    "updateSvgs:full": "npm run updateSvgs:download:full && npm run updateSvgs:format",
    "updateSvgs:incremental": "npm run updateSvgs:download:incremental && npm run updateSvgs:format"
  },
  "devDependencies": {
    "@osm-traffic-signs/converter": "workspace:*",
    "cheerio": "^1.1.2",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.2",
    "svgo": "^4.0.0",
    "typescript": "^5.9.3",
    "zod": "^4.2.1"
  }
}
