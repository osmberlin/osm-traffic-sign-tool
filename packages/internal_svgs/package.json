{
  "name": "@internal/svgs",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bleach": "rm -rf node_modules",
    "build": "bun run build:clean && bun run build:ts && bun run build:copy-svgs",
    "build:clean": "rimraf dist",
    "build:copy-svgs": "copyfiles --flat './src/data/svgs/*' './dist/data/svgs'",
    "build:ts": "tsc",
    "check": "bun run type-check && bun run format && bun run lint",
    "dev": "tsc --watch",
    "format": "oxfmt --config ../../oxfmt.config.mjs --write .",
    "format:check": "oxfmt --config ../../oxfmt.config.mjs --check .",
    "lint": "oxlint -c ../../oxlint.config.mjs .",
    "test": "echo No tests configured",
    "test:watch": "echo No tests configured",
    "type-check": "tsc --skipLibCheck --noEmit",
    "updateSvgs:clean": "rimraf ./src/data-svgs",
    "updateSvgs:download:full": "DOWNLOAD_MODE=full bun ./src/downloadAndOptimizeSvgs.ts",
    "updateSvgs:download:incremental": "DOWNLOAD_MODE=incremental bun ./src/downloadAndOptimizeSvgs.ts",
    "updateSvgs:force-refresh": "bun run updateSvgs:clean && bun run updateSvgs:download:full && bun run updateSvgs:format",
    "updateSvgs:format": "oxfmt --config ../../oxfmt.config.mjs --write ./src/data-svgs",
    "updateSvgs:full": "bun run updateSvgs:download:full && bun run updateSvgs:format",
    "updateSvgs:incremental": "bun run updateSvgs:download:incremental && bun run updateSvgs:format"
  },
  "devDependencies": {
    "@osm-traffic-signs/converter": "workspace:*",
    "cheerio": "^1.1.2",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.2",
    "svgo": "^4.0.0",
    "typescript": "^5.9.3",
    "zod": "^4.2.1"
  }
}
