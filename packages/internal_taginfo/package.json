{
  "name": "@internal/taginfo",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bleach": "rm -rf node_modules",
    "build": "tsc",
    "check": "bun run type-check && bun run lint",
    "dev": "tsc --watch",
    "format": "bun run --cwd ../.. format",
    "format:check": "bun run --cwd ../.. format:check",
    "lint": "oxlint -c ../../oxlint.config.mjs .",
    "taginfo": "bun run taginfo:generate",
    "taginfo:fetch": "bun run taginfo:generate",
    "taginfo:generate": "bun run ./src/generateTaginfoSnapshots.ts && bun run --cwd ../.. format:files -- packages/internal_taginfo/src/data",
    "test": "echo No tests configured",
    "test:watch": "echo No tests configured",
    "type-check": "tsc --skipLibCheck --noEmit"
  },
  "devDependencies": {
    "@osm-traffic-signs/converter": "workspace:*",
    "cheerio": "^1.1.2",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
