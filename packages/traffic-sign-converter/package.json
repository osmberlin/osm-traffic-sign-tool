{
  "name": "@osm-traffic-signs/converter",
  "version": "0.4.0",
  "description": "Convert traffic sign IDs to OSM tags; suggest a traffic_sign-tag based on OSM tags.",
  "keywords": [
    "openstreetmap"
  ],
  "homepage": "https://www.osm-verkehrswende.org/traffic-signs/",
  "bugs": {
    "url": "https://github.com/osmberlin/osm-traffic-sign-tool/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Tobias Jordans <t@tobiasjordans.de> (https://www.osm-verkehrswende.org/traffic-signs/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osmberlin/osm-traffic-sign-tool.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./data-svgs": {
      "import": "./dist/data-svgs/index.js",
      "default": "./dist/data-svgs/index.js",
      "types": "./dist/data-svgs/index.d.ts"
    },
    "./data-svgs/*": {
      "import": "./dist/data-svgs/*/index.js",
      "default": "./dist/data-svgs/*/index.js",
      "types": "./dist/data-svgs/*/index.d.ts"
    },
    "./data-svgs/*/loaders": {
      "import": "./dist/data-svgs/*/loaders.js",
      "default": "./dist/data-svgs/*/loaders.js",
      "types": "./dist/data-svgs/*/loaders.d.ts"
    },
    "./data-svgs/*/svgs/*": {
      "import": "./dist/data-svgs/*/svgs/*.svg",
      "default": "./dist/data-svgs/*/svgs/*.svg",
      "types": "./dist/types/svg.d.ts"
    }
  },
  "scripts": {
    "_check": "bun run format && bun run check-exports && bun run lint && bun run type-check && bun run test",
    "bleach": "rm -rf node_modules && rm -rf dist",
    "build": "bun run build:clean && bun run build:clean-svgs && bun run build:transfer-svgs && bun run build:ts && bun run build:copy-types && bun run build:copy-svgs",
    "build:clean": "rimraf dist",
    "build:clean-svgs": "rimraf ./src/data-svgs",
    "build:copy-svgs": "copyfiles -u 1 'src/data-svgs/**' 'dist'",
    "build:copy-types": "copyfiles --flat './src/types/svg.d.ts' './dist/types'",
    "build:transfer-svgs": "copyfiles -u 4 '../internal_svgs/src/data-svgs/**/*' './src/data-svgs'",
    "build:ts": "tsc",
    "build:watch": "tsc --watch",
    "check": "bun run format && bun run check-exports && bun run lint && bun run type-check && bun run test",
    "check-exports": "attw --pack . --ignore-rules cjs-resolves-to-esm internal-resolution-error no-resolution --profile node16",
    "dev": "tsc --watch",
    "format": "oxfmt --config ../../oxfmt.config.mjs --write .",
    "format:check": "oxfmt --config ../../oxfmt.config.mjs --check .",
    "lint": "oxlint -c ../../oxlint.config.mjs .",
    "release:patch": "npm version patch && bun run build && bun run check && npm run login && npm publish",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch --passWithNoTests",
    "type-check": "tsc --noEmit",
    "updatePackages:major": "bunx taze major --includeLocked --write --maturity-period 5 --exclude // && bun run updatePackages:minor && bun install",
    "updatePackages:minor": "bunx taze minor --includeLocked --write --maturity-period 5 && bun install"
  },
  "dependencies": {
    "opening_hours": "^3.12.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
