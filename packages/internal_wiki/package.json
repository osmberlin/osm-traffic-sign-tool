{
  "name": "@internal/wiki",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bleach": "rm -rf node_modules",
    "build": "bun run build:clean && bun run build:ts",
    "build:clean": "rimraf dist",
    "build:ts": "tsc",
    "check": "bun run type-check && bun run lint",
    "dev": "tsc --watch",
    "format": "bun run --cwd ../.. format",
    "format:check": "bun run --cwd ../.. format:check",
    "lint": "oxlint -c ../../oxlint.config.mjs .",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --skipLibCheck --noEmit",
    "wiki": "bun run wiki:generate",
    "wiki:downloadWiki": "bun ./src/downloadWiki/downloadWiki.ts && bun run --cwd ../.. format:files -- packages/internal_wiki",
    "wiki:generate": "bun ./src/generateWikiSnapshots.ts && bun run --cwd ../.. format:files -- packages/internal_wiki/src/data",
    "wiki:importCatalogue": "bun ./src/importWikiCatalogue/importWikiCatalogue.ts",
    "wiki:parseWiki": "bun ./src/parseWiki/parseWiki.ts && bun run --cwd ../.. format:files -- packages/internal_wiki"
  },
  "devDependencies": {
    "@osm-traffic-signs/converter": "workspace:*",
    "cheerio": "^1.1.2",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7",
    "zod": "^4.2.1"
  }
}
