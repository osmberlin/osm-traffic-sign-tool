{
  "name": "@internal/wiki",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bleach": "rm -rf .turbo && rm -rf node_modules",
    "build": "pnpm run build:clean && pnpm run build:ts",
    "build:clean": "rimraf dist",
    "build:ts": "tsc",
    "check": "pnpm run type-check && pnpm run format && pnpm run lint",
    "dev": "tsc --watch",
    "format": "oxfmt --config ../../oxfmt.config.mjs --write .",
    "format:check": "oxfmt --config ../../oxfmt.config.mjs --check .",
    "lint": "oxlint -c ../../oxlint.config.mjs .",
    "preinstall": "npx only-allow pnpm",
    "test": "echo No tests configured",
    "test:watch": "echo No tests configured",
    "type-check": "tsc --skipLibCheck --noEmit",
    "wiki": "pnpm run wiki:downloadWiki && pnpm run wiki:parseWiki",
    "wiki:downloadWiki": "bun ./src/downloadWiki/downloadWiki.ts && oxfmt --config ../../oxfmt.config.mjs --write ./",
    "wiki:parseWiki": "bun ./src/parseWiki/parseWiki.ts && oxfmt --config ../../oxfmt.config.mjs --write ./"
  },
  "devDependencies": {
    "@internal/svgs": "workspace:*",
    "@osm-traffic-signs/converter": "workspace:*",
    "cheerio": "^1.1.2",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "zod": "^4.2.1"
  }
}
